# BEGIN zfs-backup-managed (generated by gen-cron.sh -- do not hand-edit, re-run gen-cron.sh instead)
5 * * * * /REPO/snapsend.sh -m "automated_hourly_" -z -v 3 "tank/a,tank/b" 2>>/LOG || /NOTIFY "testhost hourly snapshot (groupA)"
10 0 * * * /REPO/snapsend.sh -m "automated_daily_" -z -v 3 "tank/a,tank/b" 2>>/LOG || /NOTIFY "testhost daily snapshot (groupA)"

35 * * * * /REPO/delsnaps.sh "tank/a,tank/b" "automated_hourly" -H24 2>>/LOG || /NOTIFY "testhost hourly prune (groupA)"
40 0 * * * /REPO/delsnaps.sh "tank/a,tank/b" "automated_daily" -D7 2>>/LOG || /NOTIFY "testhost daily prune (groupA)"
50 0 * * 0 /REPO/delsnaps.sh -R "backup/store" "automated_weekly" -W8 2>>/LOG || /NOTIFY "testhost weekly prune (store)"

*/15 * * * * /REPO/check-snap-age.sh "tank/a,tank/b" "automated_hourly" 90m 3h 2>>/LOG; rc=$?; [ $rc -eq 2 ] && /NOTIFY "testhost hourly stale (groupA)"; [ $rc -ge 3 ] && /NOTIFY "testhost hourly monitor BROKEN (groupA)"
0 */6 * * * /REPO/check-snap-age.sh -R "backup/store" "automated_weekly" 9d 12d 2>>/LOG; rc=$?; [ $rc -eq 2 ] && /NOTIFY "testhost weekly stale (store)"; [ $rc -ge 3 ] && /NOTIFY "testhost weekly monitor BROKEN (store)"
# END zfs-backup-managed
